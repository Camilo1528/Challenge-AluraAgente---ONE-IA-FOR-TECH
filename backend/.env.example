# ============================================
# TechStore 2026 - Variables de Entorno Seguras
# ============================================
# Copia este archivo como .env y completa TODOS los valores
# ⚠️ NUNCA uses valores por defecto en producción
# ⚠️ NUNCA subas tu .env al repositorio

# ============================================
# REQUERIDOS (sin estos valores no arranca)
# ============================================

# Google Gemini API Key (formato AQ... desde 2026)
GOOGLE_API_KEY="TU_API_KEY_DE_GEMINI_AQUI"

# Secreto para firmar tokens JWT (mínimo 32 caracteres)
SECRET_KEY="cambia-esto-por-una-clave-segura-de-al-menos-32-caracteres"

# ============================================
# OPCIONALES PERO RECOMENDADOS
# ============================================

# Admin por defecto (solo usado si no hay credenciales en base de datos)
ADMIN_USER="admin"
# ⚠️ Ya no hay contraseña por defecto. Configúrala al iniciar la app.
ADMIN_PASS=""

# Entorno: development, production, test
ENVIRONMENT="development"

# ============================================
# CORS (separados por coma)
# ============================================
# CORS_ORIGINS="https://midominio.com,https://admin.midominio.com"

# ============================================
# BASE DE DATOS
# ============================================
# DB_PATH="chat_history.db"
# DATA_RETENTION_DAYS=90

# ============================================
# CHROMA DB
# ============================================
# CHROMA_DB_DIR="./chroma_db"

# ============================================
# LOGS
# ============================================
# LOG_DIR="logs"
